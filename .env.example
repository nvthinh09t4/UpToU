# Copy this file to .env and fill in real values.
# Never commit .env to git.

# ── Domain ────────────────────────────────────────────────────────────────────
# Used to build Client__BaseUrl and Client__CrmBaseUrl inside docker-compose.
DOMAIN=yourdomain.com

# ── SQL Server ────────────────────────────────────────────────────────────────
# Must meet SQL Server complexity: uppercase + number + symbol, ≥8 chars
DB_SA_PASSWORD=123456aA@

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_BASE64_RANDOM_SECRET

# ── SMTP (SendGrid example) ───────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=REPLACE_WITH_SENDGRID_API_KEY
SMTP_FROM=noreply@yourdomain.com

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET
